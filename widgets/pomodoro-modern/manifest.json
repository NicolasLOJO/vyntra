{
  "schema": 1,
  "id": "com.vyntra.pomodoro-modern",
  "name": "Pomodoro",
  "version": "0.1.0",
  "author": { "name": "Vyntra" },
  "description": "Focus timer with configurable sessions and animated ring",
  "size": { "w": 4, "h": 4 },
  "entry": "bundle.js",
  "permissions": { "storage": true },
  "interactive": true,
  "config": {
    "work_minutes": {
      "label": "Work duration",
      "type": "number",
      "description": "Minutes per focus session",
      "default": 25,
      "min": 1,
      "max": 90
    },
    "break_minutes": {
      "label": "Short break",
      "type": "number",
      "description": "Minutes for a short break",
      "default": 5,
      "min": 1,
      "max": 30
    },
    "long_break_minutes": {
      "label": "Long break",
      "type": "number",
      "description": "Minutes for the long break",
      "default": 15,
      "min": 5,
      "max": 60
    },
    "long_break_after": {
      "label": "Long break after",
      "type": "number",
      "description": "Sessions before a long break",
      "default": 4,
      "min": 2,
      "max": 8
    },
    "accent_color": {
      "label": "Accent color",
      "type": "color",
      "description": "Color of the timer ring",
      "default": "#ef4444"
    }
  }
}
