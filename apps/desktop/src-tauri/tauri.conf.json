{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vyntra",
  "version": "0.1.0",
  "identifier": "com.vyntra.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev:vite",
    "beforeBuildCommand": "pnpm build:vite"
  },
  "app": {
    "windows": [
      {
        "label": "vyntra-surface",
        "title": "Vyntra",
        "width": 1920,
        "height": 1080,
        "transparent": true,
        "decorations": false,
        "skipTaskbar": true,
        "shadow": false,
        "resizable": false,
        "fullscreen": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' vyntra:; style-src 'self' 'unsafe-inline' vyntra:; img-src 'self' data: vyntra:; connect-src 'self' ipc: http://ipc.localhost vyntra:;",
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
